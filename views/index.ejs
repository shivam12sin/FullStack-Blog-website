<div class="author">
  <h1 class="author__heading" style="font-size: clamp(2.5rem, 5vw, 4rem); background: var(--accent-gradient); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent;">Writer's Network</h1>
  <p class="author__body">Discover ideas, stories, and expertise from writers everywhere.</p>
</div>

<section class="articles">
  <h2 class="articles__heading">Latest Posts</h2>
  <ul class="article-ul">
    <% data.forEach(post => { %>
    <li>
      <a href="/post/<%= post._id %>" style="text-decoration: none; display: block;">
        <span class="article-title"><%= post.title %></span>
      </a>
      <% if (post.author) { %>
        <a href="/author/<%= post.author._id %>" style="text-decoration: none; display: inline-block;">
          <span class="article-author-tag">by <%= post.author.username %></span>
        </a>
      <% } %>
      <% if (post.tags && post.tags.length > 0) { %>
        <div style="margin-top: 0.25rem; margin-bottom: 0.5rem;">
          <% post.tags.forEach(tag => { %>
            <a href="/tag/<%= tag %>" class="mode-badge" style="display: inline-block; margin-left: 0; margin-right: 0.5rem;"><%= tag %></a>
          <% }) %>
        </div>
      <% } %>
      <div class="article-list__date"><%= post.createdAt.toDateString() %></div>
    </li>
     <% }) %>
   
  </ul>
 <% if (nextPage!==null) { %>
   <a href="/?page=<%= nextPage%>" class="pagination">&lt; View Older Post</a>
  
 <% } %>
 
</section>

<div class="auth-container" style="margin-top: 4rem;">
  <h2 style="text-align: center; margin-bottom: 1rem;">Platform Support</h2>
  <p class="author__body" style="text-align: center; margin-bottom: 2rem; font-size: 1rem;">
    Have questions about partnerships, platform bugs, or account support? Drop us a line.
  </p>

  <form action="/support" method="POST">
    <input type="text" name="name" placeholder="Your Name" required />
    <input type="email" name="email" placeholder="Your Email Address" required />
    <textarea name="message" placeholder="How can we help you?" rows="5" required></textarea>
    <button type="submit" class="btn" style="width: 100%;">Send Message</button>
  </form>
</div>

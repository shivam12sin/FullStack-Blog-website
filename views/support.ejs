<section class="manuscript-section support-panel">
  <div class="section-heading">

    <h2>Platform Support</h2>
  </div>
  <p class="body-lg">Have questions about partnerships, bugs, or account support? Leave us a note and we'll reply with care.</p>

  <form action="/support" method="POST" class="support-form">
    <input type="text" name="name" placeholder="Your Name" required />
    <input type="email" name="email" placeholder="Your Email Address" required />
    <textarea name="message" placeholder="How can we help you?" rows="5" required></textarea>
    <button type="submit" class="btn">Send Message</button>
  </form>
</section>
